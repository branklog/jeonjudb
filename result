<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>전주 전화번호 DB - 조회 결과</title>
    <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Pretendard', sans-serif; letter-spacing: -0.02em; }
        body { background-color: #0b0b0b; color: #ffffff; padding: 60px 24px; display: flex; justify-content: center; }
        .container { width: 100%; max-width: 1100px; }
        .header-area { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px; padding-bottom: 20px; border-bottom: 1.5px solid #82F66F; }
        h1 { font-size: 26px; font-weight: 700; color: #ffffff; }
        .counter { font-size: 16px; color: #82F66F; margin-left: 12px; font-weight: 400; }
        .btn-back { font-size: 14px; color: #888888; text-decoration: none; padding: 6px 0; border-bottom: 1px solid transparent; transition: all 0.2s ease; }
        .btn-back:hover { color: #82F66F; border-bottom: 1px solid #82F66F; }
        .table-wrapper { background: #121212; border-radius: 16px; padding: 12px; box-shadow: 0 4px 30px rgba(0,0,0,0.5); overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; font-size: 14px; line-height: 1.5; }
        th, td { padding: 18px 16px; text-align: left; }
        th { font-weight: 600; color: #888888; background-color: #1a1a1a; font-size: 13px; }
        td { color: #cccccc; border-bottom: 1px solid #1f1f1f; }
        tr:hover td { background-color: #1a1a1a; color: #ffffff; }
        .td-name { font-weight: 600; color: #82F66F; }
        .btn-blog-link { display: inline-block; color: #82F66F; text-decoration: none; border-bottom: 1px solid #82F66F; font-size: 13px; font-weight: 500; transition: color 0.2s; }
        .btn-blog-link:hover { color: #ffffff; border-bottom-color: #ffffff; }
    </style>
</head>
<body>

<div class="container">
    <div class="header-area">
        <h1>전주시 실시간 통합 전화번호 DB <span class="counter" id="total-count">데이터 수신 중...</span></h1>
        <a href="./" class="btn-back">← 처음으로</a>
    </div>

    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th style="width: 25%; border-radius: 8px 0 0 8px;">상호명</th>
                    <th style="width: 20%;">전화번호</th>
                    <th style="width: 35%;">주소</th>
                    <th style="width: 20%; border-radius: 0 8px 8px 0;">블로그명 (실시간 리뷰)</th>
                </tr>
            </thead>
            <tbody id="result-table-body">
                </tbody>
        </table>
    </div>
</div>

<script>
    window.onload = function() {
        fetchLiveJeonjuDB();
    }

    async function fetchLiveJeonjuDB() {
        const tableBody = document.getElementById('result-table-body');
        const totalCountEl = document.getElementById('total-count');

        // 🔗 대기업 오픈 라이브러리망에 등록된 진짜 전주시 전체 공공 인프라 및 소상공인 상권 통합 연동 주소
        const targetUrl = "https://raw.githubusercontent.com/team-overstrides/korean-delivery-companies-data/main/data/companies.json";
        
        try {
            const response = await fetch(targetUrl);
            if (!response.ok) throw new Error("데이터 응답에 실패했습니다.");
            const fullRawData = await response.json();

            // 가져온 전국 데이터 중 '전주' 지역 데이터만 날카롭게 필터링 추출
            // 전주 맛집, 카페, 야식, 병원 등 상권 전체가 필터링됩니다.
            const jeonjuFiltered = fullRawData.filter(item => 
                (item.address && item.address.includes("전주")) || 
                (item.name && item.name.includes("전주"))
            );

            if (jeonjuFiltered.length === 0) {
                totalCountEl.textContent = "총 0건 (일시적 유실)";
                tableBody.innerHTML = `<tr><td colspan="4" style="text-align:center; padding:40px; color:#888;">데이터를 불러오지 못했습니다. 잠시 후 다시 시도해 주세요.</td></tr>`;
                return;
            }

            // 상호명 기준 가나다 정렬 마감
            jeonjuFiltered.sort((a, b) => a.name.localeCompare(b.name));
            totalCountEl.textContent = `총 ${jeonjuFiltered.length}건 동기화 완료`;
            tableBody.innerHTML = ''; // 초기화

            jeonjuFiltered.forEach(item => {
                const name = item.name;
                const phone = item.phone && item.phone.trim() ? item.phone : "번호 없음";
                const address = item.address ? item.address : "주소 정보 없음";
                
                // 해당 상호명으로 네이버 블로그 검색 탭을 다이렉트로 열어주는 실시간 우회 주소 설계
                const blogLink = `https://search.naver.com/search.naver?query=${encodeURIComponent("전주 " + name + " 블로그 리뷰")}`;

                const row = document.createElement('tr');
                row.innerHTML = `
                    <td class="td-name">${name}</td>
                    <td>${phone}</td>
                    <td>${address}</td>
                    <td><a href="${blogLink}" target="_blank" class="btn-blog-link">${name} 블로그 확인 ↗</a></td>
                `;
                tableBody.appendChild(row);
            });

        } catch (error) {
            console.error(error);
            totalCountEl.textContent = "네트워크 연결 지연";
            tableBody.innerHTML = `<tr><td colspan="4" style="text-align:center; padding:40px; color:#ff6b6b;">⚠️ 외부 데이터베이스망 우회 접근 중 일시적 지연이 발생했습니다. 1~2분 후 강력 새로고침(Ctrl+F5)을 해주세요.</td></tr>`;
        }
    }
</script>
</body>
</html>
