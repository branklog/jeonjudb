<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>전주 전화번호 DB - 결과</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Malgun Gothic', sans-serif; }
        body {
            background-color: #f8f9fa;
            padding: 40px 20px;
            display: flex;
            justify-content: center;
        }
        .container {
            background-color: #fff;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            width: 100%;
            max-width: 900px;
        }
        .header-area {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            border-bottom: 2px solid #333;
            padding-bottom: 15px;
        }
        h1 { font-size: 24px; color: #222; }
        .btn-back {
            background-color: #f1f3f5;
            color: #495057;
            border: 1px solid #ced4da;
            padding: 8px 16px;
            font-size: 14px;
            border-radius: 4px;
            cursor: pointer;
            text-decoration: none;
        }
        .btn-back:hover { background-color: #e9ecef; }
        .table-wrapper { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; font-size: 14px; }
        th, td { padding: 12px 15px; text-align: left; border-bottom: 1px solid #e0e0e0; }
        th { background-color: #f8f9fa; color: #495057; font-weight: 600; }
        tr:hover { background-color: #fafafa; }
    </style>
</head>
<body>

<div class="container">
    <div class="header-area">
        <h1>전주 전화번호 DB 조회 결과</h1>
        <!-- 처음 화면으로 돌아가는 버튼 -->
        <a href="index.html" class="btn-back">처음으로</a>
    </div>

    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>상호명</th>
                    <th>전화번호</th>
                    <th>주소</th>
                    <th>블로그명</th>
                </tr>
            </thead>
            <tbody id="result-table-body">
                <!-- 데이터가 이곳에 삽입됩니다 -->
            </tbody>
        </table>
    </div>
</div>

<script>
    // 샘플 데이터 데이터베이스 역할
    const dynamicDB = [
        { name: "전주 한옥베이커리", phone: "063-123-4567", address: "전북 전주시 완산구 한옥마을길 12", blog: "한옥마을 맛집 탐방기" },
        { name: "객리단길 커피하우스", phone: "063-987-6543", address: "전북 전주시 완산구 객사길 85", blog: "카페 투어 매니아" },
        { name: "신시가지 IT 솔루션", phone: "063-456-7890", address: "전북 전주시 완산구 홍산로 23", blog: "테크 리뷰 일지" },
        { name: "덕진공원 비빔밥", phone: "063-222-3333", address: "전북 전주시 덕진구 권삼득로 150", blog: "전주 로컬 맛집 가이드" }
    ];

    // 페이지가 로드되면 실행되는 함수
    window.onload = function() {
        const tableBody = document.getElementById('result-table-body');
        
        // 실제로는 여기서 주소창의 파라미터를 읽어와 필터링을 할 수 있습니다.
        // 현재는 버튼을 누르고 들어오면 바로 리스트를 뿌려주도록 설정했습니다.
        dynamicDB.forEach(item => {
            const row = document.createElement('tr');
            row.innerHTML = `
                <td><strong>${item.name}</strong></td>
                <td>${item.phone}</td>
                <td>${item.address}</td>
                <td>${item.blog}</td>
            `;
            tableBody.appendChild(row);
        });
    }
</script>

</body>
</html>
